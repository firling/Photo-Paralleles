# Photos Parallèles — production environment.
# Copy to `.env.production` (gitignored) and fill in real secrets, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# Generate secrets with e.g.  openssl rand -base64 48

# ─── Site / domain ───────────────────────────────────────────────────────────
# Public apex domain. Used by Traefik routing AND inlined into the build
# (canonical URLs). Umami is served on analytics.<ROOT_DOMAIN>.
ROOT_DOMAIN="photosparalleles.fr"
NEXT_PUBLIC_APP_URL="https://photosparalleles.fr"
# Traefik TLS cert resolver name (must exist in your Traefik static config).
CERT_RESOLVER="letsencrypt"
# Host port to publish the app on (local smoke test / direct access).
# Behind Traefik in real prod you can leave the default.
APP_HOST_PORT="3000"

# ─── App database (Postgres `db` service) ────────────────────────────────────
POSTGRES_DB="photos_paralleles"
POSTGRES_USER="photos"
POSTGRES_PASSWORD="change-me-strong-db-password"
# Must match the three values above (host = `db`, the compose service name).
DATABASE_URL="postgresql://photos:change-me-strong-db-password@db:5432/photos_paralleles"

# ─── Back-office auth (future admin sessions) ────────────────────────────────
# Session signing secret. 32+ random chars.
JWT_SECRET="change-me-with-a-long-random-string-min-32-chars"
# Admin account seeded by `pnpm db:seed` (argon2-hashed).
ADMIN_EMAIL="admin@photosparalleles.fr"
ADMIN_PASSWORD="change-me-strong-admin-password"

# ─── Transactional email (future — Resend) ───────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Sender must be a Resend-verified domain (SPF/DKIM) — not @gmail.com.
MAIL_FROM="Photos Parallèles <contact@photosparalleles.fr>"
# Inbox that receives contact / order notifications.
MAIL_TO="photosparalleles@gmail.com"

# ─── Uploads (future image pipeline) ─────────────────────────────────────────
# Mount point of the `uploads` volume inside the container.
UPLOADS_DIR="/app/uploads"

# ─── Analytics: Umami (cookieless) ───────────────────────────────────────────
# Secrets for the Umami `umami-db` + `umami` services.
UMAMI_DB_PASSWORD="change-me-umami-db-password"
UMAMI_APP_SECRET="change-me-long-random-umami-secret"
# Tracking script injected into the app root layout. Fill these in AFTER you
# create the website inside Umami (see DEPLOY.md). Leave empty to disable.
#   SRC = https://analytics.<ROOT_DOMAIN>/script.js
NEXT_PUBLIC_UMAMI_SRC=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
# Back-office stats reader (server-side Umami API). In Docker the app reaches
# Umami internally. Change the default password inside Umami, then mirror it here.
# UMAMI_WEBSITE_ID falls back to NEXT_PUBLIC_UMAMI_WEBSITE_ID when empty.
UMAMI_API_URL="http://umami:3000"
UMAMI_USERNAME="admin"
UMAMI_PASSWORD="umami"
UMAMI_WEBSITE_ID=""
